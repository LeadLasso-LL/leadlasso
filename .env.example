# Server
PORT=3000
NODE_ENV=development

# Twilio — one webhook URL per event type; business is identified by the number that received the event
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Public URL where Twilio can reach this server (e.g. https://xxx.ngrok.io)
TWILIO_WEBHOOK_BASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
